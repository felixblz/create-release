{
  "name": "create-release",
  "version": "1.0.0",
  "type": "module",
  "description": "Create a release",
  "main": "dist/index.js",
  "scripts": {
    "prettier": "npx prettier . --write",
    "prettier:check": "npx prettier . --check",
