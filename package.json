    "url": "git+https://github.com/felixblz/create-release"
  },
  "author": "felixblz",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.44.1",
    "prettier": "^3.9.5"
  }
}
